{
  "name": "twig-craft",
  "displayName": "Twig + Craft CMS",
  "description": "Syntax, snippets, formatting and hover docs for Twig and Craft CMS templates",
  "version": "0.1.1",
  "publisher": "pavelMikulik",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets",
    "Formatters"
  ],
  "keywords": [
    "twig",
    "craft",
    "craftcms",
    "symfony",
    "template",
    "syntax",
    "highlighting",
    "snippets",
    "formatter",
    "prettier",
    "emmet",
    "hover"
  ],
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#1f2937",
    "theme": "dark"
  },
  "homepage": "https://github.com/SuperiorPalo/vscode-twig-craft#readme",
  "bugs": {
    "url": "https://github.com/SuperiorPalo/vscode-twig-craft/issues"
  },
  "qna": "marketplace",
  "main": "./dist/extension.js",
  "activationEvents": [
    "onLanguage:twig"
  ],
  "contributes": {
    "languages": [
      {
        "id": "twig",
        "aliases": [
          "Twig",
          "twig"
        ],
        "extensions": [
          ".twig",
          ".html.twig"
        ],
        "firstLine": "^\\{[#%]",
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "twig",
        "scopeName": "text.html.twig",
        "path": "./syntaxes/twig.tmLanguage.json",
        "embeddedLanguages": {
          "source.css": "css",
          "source.css.embedded.twig": "css",
          "source.js": "javascript",
          "source.js.embedded.twig": "javascript"
        }
      },
      {
        "scopeName": "text.html.twig.injection",
        "path": "./syntaxes/twig-injection.tmLanguage.json",
        "injectTo": [
          "text.html.basic"
        ]
      }
    ],
    "snippets": [
      {
        "language": "twig",
        "path": "./snippets/twig.code-snippets"
      },
      {
        "language": "twig",
        "path": "./snippets/craft.code-snippets"
      }
    ],
    "configurationDefaults": {
      "emmet.includeLanguages": {
        "twig": "html"
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/SuperiorPalo/vscode-twig-craft.git"
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "node esbuild.js --production",
    "watch": "node esbuild.js --watch",
    "package": "vsce package",
    "publish": "vsce publish",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@zackad/prettier-plugin-twig": "^0.17.0",
    "prettier": "^3.8.3"
  }
}
